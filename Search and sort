<!DOCTYPE html>
<html>
<head>
    <title>Sort UI</title>
    <style>
        body {
            font-family: Arial;
            margin: 40px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Search box */
        .search-box input {
            padding: 10px;
            width: 250px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        /* Buttons */
        .sort-buttons {
            display: flex;
            gap: 10px;
        }

            .sort-buttons button {
                padding: 10px 15px;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                background: #eee;
            }

                .sort-buttons button.active {
                    background: #198754; /* green */
                    color: white;
                }
    </style>
</head>
<body>

    <div class="top-bar">

        <!-- Search -->
        <div class="search-box">
            <input type="text" placeholder="Search...">
        </div>

        <!-- Sort Buttons -->
        <div class="sort-buttons">
            <button class="active">SHOW BY DATE</button>
            <button>SHOW BY TYPE</button>
        </div>

    </div>

</body>
</html>
